{
  "name": "git-wasp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:nowatch": "tauri dev --no-watch",
    "dev:web": "vite",
    "build": "tauri build",
    "build:web": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "prepare": "husky",
    "hooks:pre-commit": "lint-staged --concurrent false",
    "hooks:pre-push": "npm run test:unit -- --dir src --testTimeout=15000 && cargo test --manifest-path src-tauri/Cargo.toml --all-targets --all-features",
    "test:unit": "vitest run",
    "ladle": "ladle serve",
    "ladle:build": "ladle build",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/language": "^6",
    "@codemirror/legacy-modes": "^6",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6",
    "@codemirror/theme-one-dark": "^6",
    "@codemirror/view": "^6",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/xterm": "^6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-window": "^2.2.7",
    "zustand": "^5"
  },
  "devDependencies": {
    "@ladle/react": "^5.1.1",
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^4.1.8",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-react-refresh": "^0.4",
    "husky": "^9.1.7",
    "jsdom": "^26",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.0.4",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": "prettier --write",
    "src/**/*.{ts,tsx}": "eslint --max-warnings 0",
    "src-tauri/**/*.rs": "rustfmt --edition 2021 --config skip_children=true"
  }
}
